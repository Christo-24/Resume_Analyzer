DJANGO_SECRET_KEY=replace-with-your-django-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

DB_ENGINE=django.db.backends.postgresql
DB_NAME=resume_analyser_db
DB_USER=resume_user
DB_PASSWORD=replace-with-your-db-password
DB_HOST=localhost
DB_PORT=5432

POSTGRES_DB=resume_analyser_db
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=replace-with-your-db-password

GEMINI_API_KEY=replace-with-your-gemini-api-key
RAZORPAY_KEY_ID=replace-with-your-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-key-secret
